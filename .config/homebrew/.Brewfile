# Install:
#   brew bundle --global
# Sync (cleanup):
#   brew bundle --global --force cleanup

cask_args appdir: "/Applications", require_sha: true

tap "homebrew/cask"
tap "homebrew/cask-fonts"

# Essential
brew "git"
brew "jump"
brew "yadm"
brew "zsh"
brew "zsh-completions"
brew "zsh-syntax-highlighting"
brew "font-hack-nerd-font"

# Neovim
brew "bob"
brew "fzf"
brew "lazygit"
cask "ghostty"

